<?xml version="1.0"?>
<!--
  Push-T environment: Cylinder pusher robot
  ==========================================
  Geometry  : cylinder, radius = 1 cm, height = 5 cm (matches T block thickness)
  Control   : two prismatic joints — x_joint (along X) then y_joint (along Y)
  Workspace : 1 m × 1 m  →  x ∈ [−0.5, 0.5] m,  y ∈ [−0.5, 0.5] m

  Kinematic chain:
    world  →[x_joint, prismatic X]→  x_carriage  →[y_joint, prismatic Y]→  pusher_link

  The world frame sits at ground level (z = 0, workspace centre).
  x_joint origin is raised to z = 0.025 m so the pusher cylinder is vertically
  centred at the same height as the T block when both rest on z = 0.

  Inertia (pusher_link, solid cylinder r = 0.01 m, h = 0.05 m, m = 0.1 kg):
    Ixx = Iyy = m/12 × (3r² + h²) = 2.333e-5 kg·m²
    Izz       = m/2  ×  r²         = 5.000e-6 kg·m²
-->
<robot name="pusher">

  <!-- ── World (virtual fixed base) ────────────────────────────────────── -->
  <link name="world"/>

  <!-- ── X prismatic joint ─────────────────────────────────────────────── -->
  <joint name="x_joint" type="prismatic">
    <parent link="world"/>
    <child  link="x_carriage"/>
    <!-- Lift to T block mid-height so pusher contacts the block face-on -->
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.5" upper="0.5" effort="100.0" velocity="2.0"/>
    <dynamics damping="1.0" friction="0.0"/>
  </joint>

  <link name="x_carriage">
    <inertial>
      <!-- Massless carriage; small dummy inertia for numerical stability -->
      <mass value="0.001"/>
      <inertia ixx="1e-9" iyy="1e-9" izz="1e-9" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ── Y prismatic joint ─────────────────────────────────────────────── -->
  <joint name="y_joint" type="prismatic">
    <parent link="x_carriage"/>
    <child  link="pusher_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5" upper="0.5" effort="100.0" velocity="2.0"/>
    <dynamics damping="1.0" friction="0.0"/>
  </joint>

  <!-- ── Pusher end-effector: cylinder ────────────────────────────────── -->
  <link name="pusher_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia
        ixx="2.333e-5"  iyy="2.333e-5"  izz="5.000e-6"
        ixy="0"         ixz="0"          iyz="0"/>
    </inertial>
    <!-- Cylinder axis is along Z by URDF convention -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0.20 0.40 0.80 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.05"/>
      </geometry>
    </collision>
  </link>

</robot>
